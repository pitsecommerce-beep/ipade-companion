# Variables públicas del frontend (Vite las inyecta en el bundle — NO pongas aquí
# secretos como la API key de Anthropic; esa va en los secrets de la Edge Function).
#
# Copia este archivo a .env.local para desarrollo y configúralo como secrets/vars
# del repositorio para el despliegue en GitHub Pages.

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica

# Opcional: base path del sitio. Por defecto "/ipade-companion/".
# Usa "/" si despliegas en un dominio propio.
# VITE_BASE=/ipade-companion/
